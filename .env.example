# Copie este arquivo para .env.local e preencha com seus valores do Supabase
# No Vercel: Settings → Environment Variables → adicione as duas variáveis abaixo

# URL do projeto Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública do Supabase (Project Settings → API → anon / public)
# Esta chave é segura para o frontend — a proteção dos dados é feita pelo RLS no Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# NUNCA adicione a service_role key aqui — ela dá acesso total ao banco
